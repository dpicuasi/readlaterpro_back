# Variables de entorno - ReadLaterPro Backend
# Copia este archivo como .env y completa los valores

# Servidor
PORT=3000
NODE_ENV=development

# MongoDB local
MONGODB_URI=mongodb://localhost:27017/readlater-pro

# JWT
JWT_SECRET=cambia_este_secreto_por_uno_seguro_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# OpenRouter API
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# App
APP_NAME=ReadLaterPro
FRONTEND_URL=http://localhost:8081

# Notificaciones push (expo-server-sdk)
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_PRIORITY_CRON=0 15 * * *
# Cron: 0 15 * * * = todos los dias a las 3pm UTC
NOTIFICATIONS_TZ=America/Guayaquil
